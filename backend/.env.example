# AI 漏洞分析平台 — 后端环境变量
# 复制为 .env 并填入实际值

# OpenAI / LLM API
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Database (async MySQL via asyncmy)
DB_URL=mysql+asyncmy://user:password@localhost:3306/vuln_platform

# Redis
REDIS_URL=redis://localhost:6379/0
